PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/chitram
JWT_SECRET=replace-with-a-long-random-secret
API_KEY=your-tmdb-api-key
FRONTEND_URL=http://localhost:8080,http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend SMTP: https://resend.com/docs/send-with-nodemailer-smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=2525
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
SMTP_FROM="Chitram <noreply@your-verified-domain.com>"

# Never expose or log OTPs in production.
SHOW_DEV_OTP=false
ALLOW_DEV_OTP_LOG=false
